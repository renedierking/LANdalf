@namespace LANdalf.UI.Components
@using LANdalf.UI.ApiClient
@using LANdalf.UI.Services

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="Device.Name"
                          Label="Name"
                          Required="true"
                          RequiredError="Name is required"
                          MaxLength="64"
                          Counter="64"
                          Immediate="true"
                          Validation="@(new Func<string?, string?>(ValidationService.ValidateName))"
                          Variant="Variant.Outlined" />

            <MudTextField @bind-Value="Device.MacAddress"
                          Label="MAC Address"
                          Required="true"
                          RequiredError="MAC Address is required"
                          Immediate="true"
                          Validation="@(new Func<string?, string?>(ValidationService.ValidateMacAddress))"
                          Variant="Variant.Outlined"
                          HelperText="Format: XX:XX:XX:XX:XX:XX, XX-XX-XX-XX-XX-XX, or XXXXXXXXXXXX" />

            <MudTextField @bind-Value="Device.IpAddress"
                          Label="IP Address (optional)"
                          Immediate="true"
                          Validation="@(new Func<string?, string?>(ValidationService.ValidateIpAddress))"
                          Variant="Variant.Outlined" />

            <MudTextField @bind-Value="Device.BroadcastAddress"
                          Label="Broadcast Address (optional)"
                          Immediate="true"
                          Validation="@(new Func<string?, string?>(ValidationService.ValidateIpAddress))"
                          Variant="Variant.Outlined" />

            <MudAutocomplete @bind-Value="Device.GroupName"
                             Label="Group (optional)"
                             Immediate="true"
                             Dense="true"
                             Variant="Variant.Outlined"
                             CoerceValue="true"
                             CoerceText="true"
                             ResetValueOnEmptyText="true"
                             SelectValueOnTab="true"
                             SearchFunc="@SearchGroups"
                             HelperText="Organize devices into groups (e.g., Gaming, Work, Media Server)" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
            <MudButton OnClick="Cancel">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Save</MudButton>
        </MudStack>
    </DialogActions>
</MudDialog>



@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public PcDeviceDTO Device { get; set; } = null!;

    [Parameter]
    public IDeviceValidationService ValidationService { get; set; } = null!;

    [Parameter]
    public IEnumerable<string>? GroupNames { get; set; }

    private IEnumerable<string> _groups = Array.Empty<string>();

    protected override void OnParametersSet() {
        _groups = GroupNames?
            .Where(g => !string.IsNullOrWhiteSpace(g))
            .Select(g => g.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray()
            ?? Array.Empty<string>();
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok(Device));

    private void Cancel() => MudDialog.Cancel();

    private Task<IEnumerable<string>> SearchGroups(string? value, CancellationToken cancellationToken) {
        if (string.IsNullOrEmpty(value)) {
            return Task.FromResult<IEnumerable<string>>(_groups);
        }
        return Task.FromResult<IEnumerable<string>>(_groups.Where(g => g.Contains(value, StringComparison.OrdinalIgnoreCase)));
    }
}
