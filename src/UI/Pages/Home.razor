@page "/"
@namespace LANdalf.UI.Pages
@using LANdalf.UI.ApiClient
@using LANdalf.UI.Services
@using LANdalf.UI.Components
@using System.Threading.Tasks
@inject LANdalfApiService LANdalfApiService
@inject IDialogService DialogService
@inject IDeviceValidationService ValidationService
@inject ViewPreferenceService ViewPreferenceService
@inject IJSRuntime JsRuntime
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>LANdalf</PageTitle>

@if (!IsLoading) {
    @if (ViewPreferenceService.IsTableView) {
        <MudDataGrid Items="devices"
                     MultiSelection="false"
                     Filterable="true"
                     Dense="true"
                     ReadOnly="true"
                     Bordered="true">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Devices</MudText>
                <MudSpacer />
                <MudButtonGroup Class="ma-0 pa-0 mr-2" Color="Color.Default" Variant="Variant.Outlined">
                    <MudIconButton Icon="@Icons.Material.Filled.ViewModule"
                                   OnClick="ToggleView"
                                   aria-label="Switch to Card View" />
                </MudButtonGroup>
                <MudButtonGroup Class="ma-0 pa-0" Color="Color.Success" Variant="Variant.Filled">
                    <MudButton OnClick="@(() => OpenDeviceDialog())">
                        Add New Device
                    </MudButton>
                </MudButtonGroup>
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.Name" Title="Name" />
                <PropertyColumn Property="x => x.MacAddress" Title="MAC Address" />
                <PropertyColumn Property="x => x.IpAddress" Title="IP Address" />
                <TemplateColumn>
                    <CellTemplate>
                        <MudButton ButtonType="ButtonType.Button" Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@(async () => await WakePcDevice(context.Item))">
                            Start
                        </MudButton>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn>
                    <CellTemplate>
                        <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit"
                                       OnClick="@(() => OpenDeviceDialog(context.Item))" />
                        <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete"
                                       OnClick="@(() => DeleteDeviceAsync(context.Item))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="PcDeviceDTO" />
            </PagerContent>
        </MudDataGrid>
    } else {
        <MudStack Spacing="3">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">Devices</MudText>
                <MudStack Row="true" Spacing="2">
                    <MudButtonGroup Class="ma-0 pa-0" Color="Color.Default" Variant="Variant.Outlined">
                        <MudIconButton Icon="@Icons.Material.Filled.TableRows"
                                       OnClick="ToggleView"
                                       aria-label="Switch to Table View" />
                    </MudButtonGroup>
                    <MudButtonGroup Class="ma-0 pa-0" Color="Color.Success" Variant="Variant.Filled">
                        <MudButton OnClick="@(() => OpenDeviceDialog())">
                            Add New Device
                        </MudButton>
                    </MudButtonGroup>
                </MudStack>
            </MudStack>

            @if (devices.Any()) {
                <MudGrid Spacing="3">
                    @foreach (var device in devices) {
                        <MudItem xs="12" sm="6" md="4">
                            <DeviceCard Device="device"
                                        OnStartClick="@(async () => await WakePcDevice(device))"
                                        OnEditClick="@(() => OpenDeviceDialog(device))"
                                        OnDeleteClick="@(async () => await DeleteDeviceAsync(device))" />
                        </MudItem>
                    }
                </MudGrid>
            } else {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No devices found. Click "Add New Device" to get started.
                </MudAlert>
            }
        </MudStack>
    }
} else {
    <MudStack Class="mt-5" Justify="Justify.Center" AlignItems="AlignItems.Center">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </MudStack>
}

@code {

    private IEnumerable<PcDeviceDTO> devices = new List<PcDeviceDTO>();
    private bool IsLoading { get; set; }


    protected override async Task OnInitializedAsync() {
        ViewPreferenceService.OnViewChanged += StateHasChanged;
        await ViewPreferenceService.LoadViewFromStorage(JsRuntime);
        await LoadData();
    }

    private async Task LoadData() {
        try {
            IsLoading = true;
            var result = await LANdalfApiService.GetAllPcDevicesAsync(CancellationToken);
            if (result.IsError) {
                await DialogService.ShowMessageBoxAsync("Error", result.Error!.Message);
            } else {
                devices = result.Value!;
            }
        } finally {
            IsLoading = false;
        }
    }

    private async Task RefreshData() {
        var result = await LANdalfApiService.GetAllPcDevicesAsync(CancellationToken);
        if (result.IsError) {
            await DialogService.ShowMessageBoxAsync("Error", result.Error!.Message);
        } else {
            devices = result.Value!;
            StateHasChanged();
        }
    }

    private async Task ToggleView() {
        await ViewPreferenceService.ToggleView(JsRuntime);
    }

    private async Task OpenDeviceDialog(PcDeviceDTO? device = null) {
        var isNewDevice = device == null;
        var deviceToEdit = device ?? new PcDeviceDTO();

        var parameters = new DialogParameters {
            { "Device", deviceToEdit },
            { "ValidationService", ValidationService },
            { "OnCancel", EventCallback.Factory.Create(this, () => {}) },
            { "OnSubmit", EventCallback.Factory.Create<PcDeviceDTO>(this, async (editedDevice) => {
                if (isNewDevice) {
                    var createDTO = new PcCreateDto {
                        Name = editedDevice.Name,
                        MacAddress = editedDevice.MacAddress,
                        IpAddress = editedDevice.IpAddress,
                        BroadcastAddress = editedDevice.BroadcastAddress
                    };
                    var resultAdd = await LANdalfApiService.AddPcDeviceAsync(createDTO, CancellationToken);
                    if (resultAdd.IsSuccess) {
                        await RefreshData();
                        Snackbar.Add($"Device '{editedDevice.Name}' added successfully", Severity.Success);
                    } else {
                        await DialogService.ShowMessageBoxAsync("Error", resultAdd.Error!.Message);
                    }
                } else {
                    var resultUpdate = await LANdalfApiService.UpdatePcDevice(editedDevice, CancellationToken);
                    if (resultUpdate.IsSuccess) {
                        await RefreshData();
                        Snackbar.Add($"Device '{editedDevice.Name}' updated successfully", Severity.Success);
                    } else {
                        await DialogService.ShowMessageBoxAsync("Error", resultUpdate.Error!.Message);
                    }
                }
            }) }
        };

        var options = new DialogOptions {
            BackdropClick = false,
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        await DialogService.ShowAsync<DeviceEditDialog>(
            isNewDevice ? "Add New Device" : "Edit Device",
            parameters,
            options
        );
    }

    private async Task DeleteDeviceAsync(PcDeviceDTO item) {
        var msgResult = await DialogService.ShowMessageBoxAsync(
            title: "Delete Device",
            message: $"Do you really want to delete the device '{item.Name}'?",
            yesText: "Delete",
            noText: "Cancel"
        );
        if (msgResult is not true) {
            return;
        }

        var result = await LANdalfApiService.DeletePcDeviceAsync(item.Id, CancellationToken);
        if (result.IsSuccess) {
            await RefreshData();
            Snackbar.Add($"Device '{item.Name}' deleted successfully", Severity.Success);
        } else {
            await DialogService.ShowMessageBoxAsync("Error", result.Error!.Message);
        }
    }

    private async Task WakePcDevice(PcDeviceDTO item) {
        var result = await LANdalfApiService.WakePcDeviceAsync(item.Id, CancellationToken);
        if (result.IsError) {
            await DialogService.ShowMessageBoxAsync("Error", result.Error!.Message);
        } else {
            Snackbar.Add($"Wake-on-LAN packet sent to '{item.Name}'", Severity.Success);
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync() {
        ViewPreferenceService.OnViewChanged -= StateHasChanged;
    }
}
