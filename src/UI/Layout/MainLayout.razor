@namespace LANdalf.UI.Layout
@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject ThemeService ThemeService
@inject IJSRuntime JsRuntime

@* Required *@
<MudThemeProvider @bind-IsDarkMode="isDarkMode" Theme="ThemeService.GetCurrentTheme()" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="w-100">
            <MudText Typo="Typo.h6">LANdalf</MudText>
            <MudSpacer />
            <MudIconButton Icon="@(isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="@ToggleTheme"
                           aria-label="@(isDarkMode ? "Light Mode" : "Dark Mode")" />
        </MudStack>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-5">
            @Body
        </MudContainer>
    </MudMainContent>

    <MudAppBar Bottom="true" Fixed="true" Elevation="1" Style="top: auto; bottom: 0; background: transparent;">
        <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="3" Class="w-100">
            <MudText Typo="Typo.caption" Color="Color.Default">LANdalf v1.0.0</MudText>
            <MudLink Href="https://github.com/renedierking/LANdalf" Target="_blank" Typo="Typo.caption">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Custom.Brands.GitHub" Size="Size.Small" />
                    <span>GitHub</span>
                </MudStack>
            </MudLink>
        </MudStack>
    </MudAppBar>
</MudLayout>

@code {
    private bool isDarkMode;

    protected override async Task OnInitializedAsync()
    {
        ThemeService.OnThemeChanged += StateHasChanged;
        await ThemeService.LoadThemeFromStorage(JsRuntime);
        isDarkMode = ThemeService.IsDarkMode;
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleTheme(JsRuntime);
        isDarkMode = ThemeService.IsDarkMode;
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        ThemeService.OnThemeChanged -= StateHasChanged;
    }
}
